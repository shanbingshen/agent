# Application
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=30
DATABASE_URL=postgresql+psycopg://arthra:arthra@app-db:5432/arthra
LANGGRAPH_CHECKPOINT_NAMESPACE=arthra-agent-v2
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Bootstrap account (change before any non-local deployment)
BOOTSTRAP_ADMIN_EMAIL=admin@arthra.local
BOOTSTRAP_ADMIN_PASSWORD=Arthra@123456

# OpenAI-compatible chat model (Qwen / DeepSeek / OpenAI / Ollama / vLLM)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.1

# Supervisor semantic routing; leave model empty to reuse LLM_MODEL
SUPERVISOR_SEMANTIC_ROUTING_ENABLED=true
SUPERVISOR_LLM_MODEL=
SUPERVISOR_ROUTE_CONFIDENCE_THRESHOLD=0.65

# Embeddings (OpenAI-compatible); leave empty to use deterministic local demo embeddings
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=384

# ThingsBoard CE
THINGSBOARD_URL=http://thingsboard:9090
THINGSBOARD_USERNAME=tenant@thingsboard.org
THINGSBOARD_PASSWORD=tenant
THINGSBOARD_REQUEST_TIMEOUT=15

# AI daily summary (local time, generated once per day)
DAILY_SUMMARY_ENABLED=true
DAILY_SUMMARY_HOUR=8
DAILY_SUMMARY_TIMEZONE=Asia/Shanghai

# Compressed-air deterministic analysis
COMPRESSOR_DEFAULT_SYSTEM_ID=AIR-SYS-01
COMPRESSOR_ANALYSIS_WINDOW_HOURS=24
COMPRESSOR_HISTORY_INTERVAL_SECONDS=180
COMPRESSOR_MIN_DATA_COVERAGE=0.8
COMPRESSOR_MIN_PRESSURE_MPA=0.65
COMPRESSOR_MAX_PRESSURE_MPA=0.8
COMPRESSOR_PRESSURE_FLUCTUATION_WARNING_MPA=0.08
COMPRESSOR_IDLE_WARNING_MINUTES=30
COMPRESSOR_UNLOAD_RATE_WARNING_PCT=20
COMPRESSOR_FREQUENT_STARTS_PER_HOUR=6
COMPRESSOR_PRODUCTION_START_HOUR=8
COMPRESSOR_PRODUCTION_END_HOUR=18
COMPRESSOR_UNLOAD_SAVINGS_FACTOR=0.5

# Control guardrails
CONTROL_PLAN_TTL_SECONDS=600
CONTROL_ALLOWED_METHODS=setPowerLimit,setMode,start,stop
CONTROL_ALLOWED_DEVICE_TYPES=ems,meter,compressor
CONTROL_MAX_POWER_LIMIT_KW=500

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
