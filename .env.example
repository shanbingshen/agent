# Application
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=30
DATABASE_URL=postgresql+psycopg://arthra:arthra@app-db:5432/arthra
LANGGRAPH_CHECKPOINT_NAMESPACE=arthra-agent-v2
CORS_ORIGINS=http://localhost:18090,http://127.0.0.1:18090

# Bootstrap account (change before any non-local deployment)
BOOTSTRAP_ADMIN_EMAIL=admin@arthra.local
BOOTSTRAP_ADMIN_PASSWORD=Arthra@123456

# OpenAI-compatible chat model (Qwen / DeepSeek / OpenAI / Ollama / vLLM)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.1

# Optional local Ollama OpenAI-compatible API; uncomment to use local models.
# Native LR/macOS/Windows run: http://127.0.0.1:11434/v1
# Docker API container calling host Ollama: http://host.docker.internal:11434/v1
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=qwen3.5:9b-q4_K_M
# NO_PROXY=127.0.0.1,localhost

# Supervisor semantic routing; leave model empty to reuse LLM_MODEL
SUPERVISOR_SEMANTIC_ROUTING_ENABLED=true
SUPERVISOR_LLM_MODEL=
SUPERVISOR_ROUTE_CONFIDENCE_THRESHOLD=0.65

# Deterministic specialist results are always retained; Qwen only explains them.
# Leave model empty to reuse LLM_MODEL.
COMPRESSOR_EXPERT_LLM_ENABLED=true
COMPRESSOR_EXPERT_LLM_MODEL=
POWER_EXPERT_LLM_ENABLED=true
POWER_EXPERT_LLM_MODEL=

# Embeddings (OpenAI-compatible); leave empty to use deterministic local demo embeddings
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=384

# Optional local Ollama embeddings; keep 384 unless the pgvector migration changes.
# EMBEDDING_API_KEY=ollama
# EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
# EMBEDDING_MODEL=qwen3-embedding:0.6b
# EMBEDDING_DIMENSIONS=384

# RAG retrieval is limited to the authenticated tenant and active factory.
RAG_RETRIEVAL_ENABLED=true
RAG_TOP_K=4
RAG_MIN_SCORE=0.2

# ThingsBoard CE
THINGSBOARD_URL=http://thingsboard:9090
THINGSBOARD_USERNAME=tenant@thingsboard.org
THINGSBOARD_PASSWORD=tenant
THINGSBOARD_REQUEST_TIMEOUT=15

# Unified industrial data reads: thingsboard / mock / timeseries_api
INDUSTRIAL_DATA_PROVIDER=thingsboard
# Optional JSON file; empty uses the built-in deterministic 24-hour Mock dataset
INDUSTRIAL_DATA_MOCK_FILE=
# Base URL must expose the unified /devices contract documented in README
TIMESERIES_API_URL=
TIMESERIES_API_TOKEN=
TIMESERIES_API_TIMEOUT=15

# AI daily summary (local time, generated once per day)
DAILY_SUMMARY_ENABLED=true
DAILY_SUMMARY_HOUR=8
DAILY_SUMMARY_TIMEZONE=Asia/Shanghai

# Compressed-air deterministic analysis
COMPRESSOR_DEFAULT_SYSTEM_ID=AIR-SYS-01
COMPRESSOR_ANALYSIS_WINDOW_HOURS=24
COMPRESSOR_HISTORY_INTERVAL_SECONDS=180
COMPRESSOR_MIN_DATA_COVERAGE=0.8
COMPRESSOR_MIN_PRESSURE_MPA=0.65
COMPRESSOR_MAX_PRESSURE_MPA=0.8
COMPRESSOR_PRESSURE_FLUCTUATION_WARNING_MPA=0.08
COMPRESSOR_IDLE_WARNING_MINUTES=30
COMPRESSOR_UNLOAD_RATE_WARNING_PCT=20
COMPRESSOR_FREQUENT_STARTS_PER_HOUR=6
COMPRESSOR_PRODUCTION_START_HOUR=8
COMPRESSOR_PRODUCTION_END_HOUR=18
COMPRESSOR_UNLOAD_SAVINGS_FACTOR=0.5

# Power demand and power-quality deterministic analysis
POWER_ANALYSIS_WINDOW_HOURS=24
POWER_HISTORY_INTERVAL_SECONDS=60
POWER_MIN_DATA_COVERAGE=0.8
POWER_DECLARED_DEMAND_KW=100
POWER_NOMINAL_VOLTAGE_V=380
POWER_VOLTAGE_DEVIATION_PCT=5
POWER_VOLTAGE_UNBALANCE_PCT=2
POWER_CURRENT_UNBALANCE_PCT=10
POWER_FACTOR_MIN=0.9
POWER_THDU_MAX_PCT=5
POWER_THDI_MAX_PCT=15

# Control guardrails
CONTROL_PLAN_TTL_SECONDS=600
CONTROL_ALLOWED_METHODS=setPowerLimit,setMode,start,stop
CONTROL_ALLOWED_DEVICE_TYPES=ems,meter,compressor
CONTROL_MAX_POWER_LIMIT_KW=500

# Frontend
VITE_API_BASE_URL=http://localhost:18089/api/v1
